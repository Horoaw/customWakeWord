*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual envs
.venv/
venv/
env/
.env
.env.*

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# ML / model artifacts
*.bin
*.safetensors
*.pt
*.pth
*.ckpt
*.onnx
*.h5
*.gguf
*.mlx
checkpoints/
runs/
wandb/
mlruns/
